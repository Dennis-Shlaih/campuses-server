generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Campus {
  id          Int       @id @default(autoincrement())
  name        String
  address     String
  imageUrl    String    @default("https://placehold.co/400x200?text=Campus")
  description String?
  students    Student[]
}

model Student {
  id        Int     @id @default(autoincrement())
  firstName String
  lastName  String
  email     String  @unique
  imageUrl  String  @default("https://placehold.co/150x150?text=Student")
  gpa       Float   @default(0.0)
  campusId  Int?
  campus    Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)
}